# URL publik situs (canonical, OG, metadataBase). Samakan dengan domain CMS production.
NEXT_PUBLIC_SITE_URL=https://www.aytiindopanel.com

# Disable enterprise publish orchestration and use Git/Vercel deployment flow instead.
# CMS_ENABLE_GLOBAL_PUBLISH — omit or true/1/yes for full publish UI (default when unset).
CMS_ENABLE_GLOBAL_PUBLISH=false

# Opsional — setelah publish global sukses (draft→live + revalidate), server melakukan POST ke URL ini untuk memicu deployment production.
# Wajib HTTPS (http ditolak). Retry ringan & jeda antar-deploy sukses diterapkan di server.
# Buat Deploy Hook: Vercel → Project → Settings → Git → Deploy Hooks → Add (salin URL https).
# CMS_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/...
# Alias pendek (opsional): CMS_DEPLOY_HOOK / VERCEL_DEPLOY_HOOK — nilai sama dengan URL di atas.
# VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/...

# Opsional — monitoring status build di panel CMS (polling GET /api/site-content/vercel-deployment-status).
# Token hanya dipakai di server; alternatif nama: VERCEL_API_TOKEN. Team scope: VERCEL_TEAM_ID (slug atau id).
# CMS_VERCEL_API_TOKEN=
# VERCEL_TEAM_ID=
